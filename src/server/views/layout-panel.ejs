<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= typeof title !== 'undefined' ? title + ' — ' : 'Панель — ' %>Anxiety</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
    <link rel="stylesheet" href="/css/panel.css">
</head>
<body class="panel-body">
    <nav class="navbar">
        <div class="navbar-inner">
            <a href="/" class="navbar-brand">
                <span class="brand-icon">◆</span>
                <span class="brand-text">ANXIETY</span>
            </a>
            <div class="navbar-links">
                <a href="/" class="nav-link">Сайт</a>
                <a href="/api/panel" class="nav-link active">Панель</a>
                <a href="/api/panel/users" class="nav-link">Пользователи</a>
                <a href="/api/panel/products" class="nav-link">Товары</a>
                <a href="/api/panel/builds" class="nav-link">Билды</a>
                <form action="/auth/logout" method="POST" class="nav-form">
                    <button type="submit" class="nav-link nav-logout">Выйти</button>
                </form>
            </div>
        </div>
    </nav>

    <% if (flash && flash.error) { %>
    <div class="flash flash-error"><%= flash.error %></div>
    <% } %>
    <% if (flash && flash.success) { %>
    <div class="flash flash-success"><%= flash.success %></div>
    <% } %>

    <main class="panel-main">
        <%- body %>
    </main>

    <footer class="footer">
        <div class="footer-inner">
            <span>ANXIETY Panel · <a href="/">aesthesia.xyz</a></span>
        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
