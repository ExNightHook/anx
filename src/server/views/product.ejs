<%- include('layout', { title: product.name, body: `
<section class="product-page">
    <div class="section-inner">
        <div class="product-detail">
            <div class="product-detail-image">
                ${product.image_url
                    ? '<img src="' + product.image_url + '" alt="' + (product.name || '') + '">'
                    : '<div class="product-card-placeholder large">◆</div>'
                }
            </div>
            <div class="product-detail-info">
                <h1 class="product-detail-title">${product.name}</h1>
                ${product.short_desc ? '<p class="product-detail-short">' + product.short_desc + '</p>' : ''}
                <div class="product-detail-description">
                    ${product.description || ''}
                </div>

                ${prices.length > 0 ? `
                <div class="product-prices">
                    <h3>Тарифы</h3>
                    <div class="prices-grid">
                        ${prices.map(function(p) {
                            return \`
                        <div class="price-card">
                            <div class="price-days">\${p.days} дн.</div>
                            <div class="price-value">\${formatPrice(p.price)}</div>
                            <form action="/profile/balance/topup" method="POST">
                                <button type="submit" class="btn btn-primary btn-sm" disabled>Купить</button>
                            </form>
                        </div>
                            \`;
                        }).join('')}
                    </div>
                </div>
                ` : ''}

                ${!user ? `
                <div class="product-login-hint">
                    <a href="/auth" class="btn btn-primary">Войдите, чтобы купить</a>
                </div>
                ` : ''}
            </div>
        </div>
    </div>
</section>
` }) %>
