<%- include('layout', { title: 'Сброс пароля', body: `
<section class="auth-section">
    <div class="auth-container">
        <div class="auth-card">
            <div class="auth-header">
                <h1 class="auth-title">◆ ANXIETY</h1>
                <p class="auth-subtitle">Сброс пароля</p>
            </div>

            ${error ? '<div class="auth-error">' + error + '</div>' : ''}
            ${success ? '<div class="auth-success">' + success + '</div>' : ''}

            ${token ? `
            <form action="/auth/reset-password/confirm" method="POST" class="auth-form">
                <input type="hidden" name="token" value="${token}">
                <div class="form-group">
                    <label class="form-label">Новый пароль</label>
                    <input type="password" name="password" class="form-input" required minlength="6" autocomplete="new-password">
                </div>
                <div class="form-group">
                    <label class="form-label">Подтверждение пароля</label>
                    <input type="password" name="password2" class="form-input" required minlength="6" autocomplete="new-password">
                </div>
                <button type="submit" class="btn btn-primary btn-full">Сменить пароль</button>
            </form>
            ` : `
            <form action="/auth/reset-password/request" method="POST" class="auth-form">
                <div class="form-group">
                    <label class="form-label">Email</label>
                    <input type="email" name="email" class="form-input" required placeholder="email@example.com">
                </div>
                <div class="form-group">
                    <div class="hcaptcha-wrap" data-sitekey="${HCAPTCHA_SITE_KEY}" data-theme="dark"></div>
                </div>
                <input type="hidden" name="hcaptchaToken" id="hcaptchaToken">
                <button type="submit" class="btn btn-primary btn-full">Отправить ссылку</button>
            </form>
            `}

            <div class="auth-switch">
                <a href="/auth">Вернуться ко входу</a>
            </div>
        </div>
    </div>
</section>
` }) %>
