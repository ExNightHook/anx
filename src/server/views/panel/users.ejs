<%- include('../layout-panel', { title: 'Пользователи', body: `
<div class="panel-container">
    <h1 class="panel-title">Пользователи</h1>

    <div class="table-wrap">
        <table class="panel-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Никнейм</th>
                    <th>Email</th>
                    <th>Роль</th>
                    <th>Подписка</th>
                    <th>Баланс</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                ${users.map(function(u) {
                    const isBlocked = u.blocked === 1;
                    const subInfo = u.sub_type
                        ? (u.frozen === 1 ? '❄ ' : '') + u.sub_type + ' до ' + formatDateRu(u.expiry_date)
                        : '—';
                    return \`
                <tr class="\${isBlocked ? 'row-blocked' : ''}">
                    <td>\${u.id}</td>
                    <td><a href="javascript:void(0)" class="user-link" data-uid="\${u.id}">\${u.username}</a></td>
                    <td>\${u.email}</td>
                    <td><span class="badge badge-role">\${u.role}</span></td>
                    <td>\${subInfo}</td>
                    <td>\${formatPrice(u.balance)}</td>
                    <td>
                        \${isBlocked
                            ? '<span class="badge badge-danger">Заблокирован' + (u.block_reason ? ': ' + u.block_reason : '') + '</span>'
                            : '<span class="badge badge-success">Активен</span>'
                        }
                    </td>
                    <td class="td-actions">
                        <div class="action-group">
                            <button class="btn btn-xs btn-ghost" onclick="showAddDaysModal(\${u.id}, '\${u.username}')">+Дни</button>
                            \${isBlocked ? \`
                                <form action="/api/panel/users/\${u.id}/unblock" method="POST">
                                    <button type="submit" class="btn btn-xs btn-success">Разблокировать</button>
                                </form>
                            \` : \`
                                <button class="btn btn-xs btn-warning" onclick="showBlockModal(\${u.id}, '\${u.username}')">Блок</button>
                            \`}
                        </div>
                    </td>
                </tr>
                    \`;
                }).join('')}
            </tbody>
        </table>
    </div>
</div>

<!-- Add Days Modal -->
<div id="addDaysModal" class="modal-overlay" style="display:none">
    <div class="modal">
        <h2 class="modal-title">Добавить дни подписке</h2>
        <p class="modal-subtitle" id="addDaysTarget"></p>
        <div id="addDaysSubsList"></div>
        <form action="" method="POST" id="addDaysForm">
            <div class="form-group">
                <label class="form-label">Количество дней</label>
                <input type="number" name="days" class="form-input" min="1" value="1" required>
            </div>
            <input type="hidden" name="sub_id" id="addDaysSubId" value="">
            <div class="modal-actions">
                <button type="submit" class="btn btn-primary">Добавить</button>
                <button type="button" class="btn btn-ghost" onclick="closeModal('addDaysModal')">Отмена</button>
            </div>
        </form>
    </div>
</div>

<!-- Block Modal -->
<div id="blockModal" class="modal-overlay" style="display:none">
    <div class="modal">
        <h2 class="modal-title">Блокировка аккаунта</h2>
        <p class="modal-subtitle" id="blockTarget"></p>
        <form action="" method="POST" id="blockForm">
            <div class="form-group">
                <label class="form-label">Причина</label>
                <input type="text" name="reason" class="form-input" placeholder="Причина блокировки" required>
            </div>
            <div class="form-group">
                <label class="form-label">Длительность (дней, 0 = навсегда)</label>
                <input type="number" name="duration" class="form-input" min="0" value="0">
            </div>
            <div class="modal-actions">
                <button type="submit" class="btn btn-danger">Заблокировать</button>
                <button type="button" class="btn btn-ghost" onclick="closeModal('blockModal')">Отмена</button>
            </div>
        </form>
    </div>
</div>

<script>
function showAddDaysModal(userId, username) {
    document.getElementById('addDaysTarget').textContent = username + ' (ID: ' + userId + ')';
    document.getElementById('addDaysForm').action = '/api/panel/users/' + userId + '/add-days';
    // Load subs
    fetch('/api/panel/api/users/' + userId + '/subscriptions')
        .then(r => r.json())
        .then(subs => {
            const list = document.getElementById('addDaysSubsList');
            if (subs.length === 0) {
                list.innerHTML = '<p class="empty-state">Нет подписок</p>';
                document.getElementById('addDaysSubId').value = '';
            } else {
                list.innerHTML = subs.map(s =>
                    '<label class="radio-label"><input type="radio" name="sub_select" value="' + s.id + '" ' + (s.status==='active'?'checked':'') + '> ' +
                    s.product_name + ' — ' + s.expiry_formatted + ' (' + s.days_remaining + ' дн.)</label>'
                ).join('');
                document.getElementById('addDaysSubId').value = subs.find(s => s.status === 'active')?.id || subs[0].id;
            }
        });
    // Sync radio with hidden field
    list.addEventListener('change', () => {
        const checked = list.querySelector('input:checked');
        if (checked) document.getElementById('addDaysSubId').value = checked.value;
    });
    document.getElementById('addDaysModal').style.display = 'flex';
}

function showBlockModal(userId, username) {
    document.getElementById('blockTarget').textContent = username + ' (ID: ' + userId + ')';
    document.getElementById('blockForm').action = '/api/panel/users/' + userId + '/block';
    document.getElementById('blockModal').style.display = 'flex';
}

function closeModal(id) {
    document.getElementById(id).style.display = 'none';
}
</script>
` }) %>
