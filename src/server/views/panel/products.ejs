<%- include('../layout-panel', { title: 'Товары', body: `
<div class="panel-container">
    <h1 class="panel-title">Товары</h1>

    ${isOwner ? `
    <div class="panel-card">
        <h2 class="card-title">Добавить товар</h2>
        <form action="/api/panel/products/add" method="POST" class="inline-form">
            <input type="text" name="slug" class="form-input form-inline" placeholder="slug (url)" required>
            <input type="text" name="name" class="form-input form-inline" placeholder="Название" required>
            <input type="text" name="short_desc" class="form-input form-inline" placeholder="Краткое описание">
            <button type="submit" class="btn btn-primary btn-sm">Добавить</button>
        </form>
    </div>
    ` : ''}

    <div class="table-wrap">
        <table class="panel-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Slug</th>
                    <th>Название</th>
                    <th>Цены</th>
                    <th>Статус</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                ${products.map(function(p) {
                    const priceStr = p.prices.map(function(pr) { return pr.days + 'дн/' + formatPrice(pr.price); }).join(', ');
                    return \`
                <tr>
                    <td>\${p.id}</td>
                    <td>\${p.slug}</td>
                    <td>\${p.name}</td>
                    <td>\${priceStr || '—'}</td>
                    <td>
                        <span class="badge \${p.is_active ? 'badge-success' : 'badge-danger'}">
                            \${p.is_active ? 'Активен' : 'Заморожен'}
                        </span>
                    </td>
                    <td class="td-actions">
                        <div class="action-group">
                            \${p.is_active
                                ? '<form action="/api/panel/freeze-product/' + p.id + '" method="POST"><button type="submit" class="btn btn-xs btn-warning">Заморозить</button></form>'
                                : '<form action="/api/panel/unfreeze-product/' + p.id + '" method="POST"><button type="submit" class="btn btn-xs btn-success">Разморозить</button></form>'
                            }
                            \${isOwner ? \`
                                <button class="btn btn-xs btn-ghost" onclick="showEditModal(\${p.id}, '\${escapeHtml(p.name)}', '\${escapeHtml(p.short_desc)}', '\${escapeHtml(p.description)}', '\${escapeHtml(p.image_url)}')">Ред.</button>
                                <button class="btn btn-xs btn-ghost" onclick="showPricesModal(\${p.id}, '\${escapeHtml(p.name)}', '\${escapeHtml(priceStr)}')">Цены</button>
                                <form action="/api/panel/products/\${p.id}/delete" method="POST" onsubmit="return confirm('Удалить товар?')">
                                    <button type="submit" class="btn btn-xs btn-danger">Удалить</button>
                                </form>
                            \` : ''}
                        </div>
                    </td>
                </tr>
                    \`;
                }).join('')}
                ${products.length === 0 ? '<tr><td colspan="6" class="empty-state">Нет товаров</td></tr>' : ''}
            </tbody>
        </table>
    </div>
</div>

${isOwner ? `
<!-- Edit Product Modal -->
<div id="editModal" class="modal-overlay" style="display:none">
    <div class="modal">
        <h2 class="modal-title">Редактировать товар</h2>
        <form action="" method="POST" id="editForm">
            <div class="form-group">
                <label class="form-label">Название</label>
                <input type="text" name="name" class="form-input" id="editName" required>
            </div>
            <div class="form-group">
                <label class="form-label">Краткое описание</label>
                <input type="text" name="short_desc" class="form-input" id="editShortDesc">
            </div>
            <div class="form-group">
                <label class="form-label">Полное описание</label>
                <textarea name="description" class="form-input form-textarea" id="editDescription" rows="4"></textarea>
            </div>
            <div class="form-group">
                <label class="form-label">URL изображения</label>
                <input type="text" name="image_url" class="form-input" id="editImageUrl">
            </div>
            <div class="modal-actions">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <button type="button" class="btn btn-ghost" onclick="closeModal('editModal')">Отмена</button>
            </div>
        </form>
    </div>
</div>

<!-- Prices Modal -->
<div id="pricesModal" class="modal-overlay" style="display:none">
    <div class="modal">
        <h2 class="modal-title">Цены</h2>
        <p class="modal-subtitle" id="pricesTarget"></p>
        <form action="" method="POST" id="pricesForm">
            <div class="form-group">
                <label class="form-label">Цены (формат: дни:цена, через запятую)</label>
                <input type="text" name="prices" class="form-input" id="pricesInput" placeholder="1:50,7:250,30:1000" required>
                <p class="form-hint">Пример: 1:50,7:250,30:1000</p>
            </div>
            <div class="modal-actions">
                <button type="submit" class="btn btn-primary">Сохранить</button>
                <button type="button" class="btn btn-ghost" onclick="closeModal('pricesModal')">Отмена</button>
            </div>
        </form>
    </div>
</div>

<script>
function showEditModal(id, name, shortDesc, desc, imageUrl) {
    document.getElementById('editName').value = name;
    document.getElementById('editShortDesc').value = shortDesc;
    document.getElementById('editDescription').value = desc;
    document.getElementById('editImageUrl').value = imageUrl;
    document.getElementById('editForm').action = '/api/panel/products/' + id + '/edit';
    document.getElementById('editModal').style.display = 'flex';
}
function showPricesModal(id, name, priceStr) {
    document.getElementById('pricesTarget').textContent = name;
    document.getElementById('pricesForm').action = '/api/panel/products/' + id + '/prices';
    document.getElementById('pricesInput').value = priceStr.replace(/₽/g, '').replace(/\s*дн\//g, ':').replace(/,\s*/g, ',');
    document.getElementById('pricesModal').style.display = 'flex';
}
function closeModal(id) { document.getElementById(id).style.display = 'none'; }
</script>
` : ''}
` }) %>
