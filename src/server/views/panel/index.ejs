<%- include('../layout-panel', { title: 'Панель управления', body: `
<div class="panel-container">
    <h1 class="panel-title">Панель управления</h1>

    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-value">${stats.users}</div>
            <div class="stat-label">Пользователей</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">${stats.activeSubs}</div>
            <div class="stat-label">Активных подписок</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">${formatPrice(stats.totalRevenue)}</div>
            <div class="stat-label">Всего доход</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">${stats.productCount}</div>
            <div class="stat-label">Товаров</div>
        </div>
    </div>

    <div class="panel-actions">
        <a href="/api/panel/users" class="btn btn-primary">Пользователи</a>
        <a href="/api/panel/products" class="btn btn-ghost">Товары</a>
        <a href="/api/panel/builds" class="btn btn-ghost">Билды</a>
    </div>
</div>
` }) %>
