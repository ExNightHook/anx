<%- include('../layout-panel', { title: 'Билды', body: `
<div class="panel-container">
    <h1 class="panel-title">Билды</h1>

    ${isOwner ? `
    <div class="panel-card">
        <h2 class="card-title">Добавить билд</h2>
        <form action="/api/panel/builds/add" method="POST" class="inline-form">
            <input type="number" name="product_id" class="form-input form-inline" placeholder="Product ID (опционально)">
            <input type="text" name="version" class="form-input form-inline" placeholder="Версия (0.07)" required>
            <input type="text" name="hash" class="form-input form-inline" placeholder="Hash билда">
            <button type="submit" class="btn btn-primary btn-sm">Добавить</button>
        </form>
    </div>
    ` : ''}

    <div class="table-wrap">
        <table class="panel-table">
            <thead>
                <tr>
                    <th>ID</th>
                    <th>Версия</th>
                    <th>Продукт</th>
                    <th>Hash</th>
                    <th>Статус</th>
                    <th>Дата</th>
                    <th>Действия</th>
                </tr>
            </thead>
            <tbody>
                ${builds.map(function(b) {
                    return \`
                <tr class="\${b.is_active ? 'row-active' : ''}">
                    <td>\${b.id}</td>
                    <td>\${b.version}</td>
                    <td>\${b.product_name || '—'}</td>
                    <td><code>\${(b.hash || '').substring(0, 16)}\${(b.hash || '').length > 16 ? '…' : ''}</code></td>
                    <td>
                        <span class="badge \${b.is_active ? 'badge-success' : 'badge-muted'}">
                            \${b.is_active ? 'Активен' : 'Неактивен'}
                        </span>
                    </td>
                    <td>\${formatDateRuFull(b.created_at)}</td>
                    <td class="td-actions">
                        \${isOwner && !b.is_active ? \`
                            <form action="/api/panel/builds/\${b.id}/activate" method="POST" onsubmit="return confirm('Активировать билд ' + b.version + '?')">
                                <button type="submit" class="btn btn-xs btn-success">Активировать</button>
                            </form>
                        \` : ''}
                    </td>
                </tr>
                    \`;
                }).join('')}
                ${builds.length === 0 ? '<tr><td colspan="7" class="empty-state">Нет билдов</td></tr>' : ''}
            </tbody>
        </table>
    </div>
</div>
` }) %>
