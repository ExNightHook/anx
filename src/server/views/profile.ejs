<%- include('layout', { title: 'Профиль', body: `
<section class="profile-section">
    <div class="section-inner">
        <div class="profile-header">
            <div class="profile-avatar">◆</div>
            <div class="profile-info">
                <h1 class="profile-name">${user.username}</h1>
                <div class="profile-meta">
                    <span class="badge badge-role">${user.role}</span>
                    <span class="profile-email">${user.email}</span>
                </div>
                <div class="profile-balance">
                    Баланс: <strong>${formatPrice(user.balance)}</strong>
                    <a href="/profile/balance" class="btn btn-sm btn-ghost">Пополнить</a>
                </div>
            </div>
        </div>

        <!-- HWID Reset -->
        <div class="profile-card">
            <h2 class="card-title">HWID</h2>
            <p class="card-text">HWID: <code>${user.hwid || 'не привязан'}</code></p>
            <p class="card-hint">Сброс доступен 1 раз в ${1} месяц(ев)</p>
            ${canResetHwid ? `
            <form action="/profile/hwid-reset" method="POST">
                <button type="submit" class="btn btn-danger btn-sm" onclick="return confirm('Вы уверены? Сброс HWID доступен 1 раз в месяц')">Сбросить HWID</button>
            </form>
            ` : `<p class="card-hint text-warn">Сброс HWID временно недоступен</p>`}
        </div>

        <!-- Active Subscriptions -->
        <div class="profile-card">
            <h2 class="card-title">Подписки</h2>
            ${activeSubs.length === 0 ? '<p class="empty-state">Нет активных подписок</p>' : `
            <div class="subs-list">
                ${activeSubs.map(function(sub) {
                    const dr = daysRemaining(sub.expiry_date);
                    const isFrozen = sub.frozen === 1;
                    return \`
                <div class="sub-item \${isFrozen ? 'sub-frozen' : ''}">
                    <div class="sub-info">
                        <span class="sub-name">\${sub.product_name}</span>
                        <span class="sub-expiry">
                            \${isFrozen ? '❄ Заморожена' : dr + ' дн. осталось (' + formatDateRu(sub.expiry_date) + ')'}
                        </span>
                        <span class="sub-days-bought">\${sub.days_purchased} дн. куплено</span>
                    </div>
                    <div class="sub-actions">
                        \${isFrozen ? \`
                            <form action="/profile/unfreeze/\${sub.id}" method="POST">
                                <button type="submit" class="btn btn-sm btn-warning">Разморозить</button>
                            </form>
                        \` : \`
                            <form action="/profile/freeze/\${sub.id}" method="POST">
                                <button type="submit" class="btn btn-sm btn-ghost" onclick="return confirm('Заморозить подписку? Время будет компенсировано при разморозке.')">Заморозить</button>
                            </form>
                        \`}
                    </div>
                </div>
                    \`;
                }).join('')}
            </div>
            `}
        </div>

        <!-- Expired Subscriptions -->
        ${subscriptions.length > activeSubs.length ? `
        <div class="profile-card">
            <h2 class="card-title">История подписок</h2>
            <div class="subs-list">
                ${subscriptions.filter(function(s) { return s.status !== 'active' || new Date(s.expiry_date) <= new Date(); }).map(function(sub) {
                    return \`
                <div class="sub-item sub-expired">
                    <div class="sub-info">
                        <span class="sub-name">\${sub.product_name}</span>
                        <span class="sub-expiry text-muted">Истекла: \${formatDateRu(sub.expiry_date)}</span>
                    </div>
                </div>
                    \`;
                }).join('')}
            </div>
        </div>
        ` : ''}

        <!-- Payment History -->
        <div class="profile-card">
            <h2 class="card-title">История платежей</h2>
            ${payments.length === 0 ? '<p class="empty-state">Нет платежей</p>' : `
            <div class="payments-list">
                ${payments.map(function(p) {
                    return \`
                <div class="payment-item">
                    <span class="payment-desc">\${p.description || 'Пополнение'}</span>
                    <span class="payment-amount">\${formatPrice(p.amount)}</span>
                    <span class="payment-date">\${formatDateRuFull(p.created_at)}</span>
                    <span class="badge \${p.status === 'completed' ? 'badge-success' : 'badge-pending'}">\${p.status}</span>
                </div>
                    \`;
                }).join('')}
            </div>
            `}
        </div>
    </div>
</section>
` }) %>
